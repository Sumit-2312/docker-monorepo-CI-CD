{
  "name": "deploy-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start:http-server": "cd ./apps/Http-server && npm run start",
    "start:ws-server": "cd ./apps/websocket-server && npm run start",
    "start:react-server": "cd ./apps/React-app && npm run start"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
